datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// Enums (Prisma emulates enums on SQLite using TEXT check constraints)
enum Role {
  MEMBER
  ADMIN
}

enum PlanTier {
  SILVER
  GOLD
  PLATINUM
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  PENDING
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// 1. User Model
model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  password      String?
  phone         String?
  city          String?
  role          Role            @default(MEMBER)
  image         String?
  
  // NextAuth standard relations
  accounts      Account[]
  sessions      Session[]
  
  // AB Gym business relations
  memberships   Membership[]
  payments      Payment[]
  fitnessGoals  FitnessGoal[]
  workoutLogs   WorkoutLog[]
  progress      ProgressEntry[]

  // FiTLiFe Plus tracker relations
  calorieLogs   DailyCalorieLog[]
  dietPlans     DietPlan[]
  stepLogs      StepLog[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// 2. NextAuth standard models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 3. Plan Model
model Plan {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  price       Float
  duration    Int          // In months
  tier        PlanTier
  description String?
  features    String       // JSON string list, e.g. '["feature1", "feature2"]'
  popular     Boolean      @default(false)
  active      Boolean      @default(true)
  
  memberships Membership[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// 4. Membership Model
model Membership {
  id         String           @id @default(cuid())
  userId     String
  planId     String
  status     MembershipStatus @default(PENDING)
  cardNumber String           @unique
  startDate  DateTime
  endDate    DateTime
  autoRenew  Boolean          @default(false)
  
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       Plan             @relation(fields: [planId], references: [id])
  payments   Payment[]

  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

// 5. Payment Model
model Payment {
  id                String        @id @default(cuid())
  userId            String
  membershipId      String?
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  description       String?

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership        Membership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// 6. GymLocation Model
model GymLocation {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String
  address   String
  phone     String?
  email     String?
  lat       Float?
  lng       Float?
  amenities String   // JSON string list, e.g. '["WiFi", "Cardio Zone"]'
  timings   String?
  rating    Float?   @default(4.5)
  active    Boolean  @default(true)
  imageUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 7. WorkoutPlan Model
model WorkoutPlan {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  category    String?
  difficulty  String?           // BEGINNER / INTERMEDIATE / ADVANCED
  duration    Int?              // in minutes
  calories    Int?
  description String?
  imageUrl    String?
  featured    Boolean           @default(false)
  
  exercises   WorkoutExercise[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// 8. Exercise Model
model Exercise {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  muscleGroup  String
  equipment    String
  difficulty   String
  instructions String
  tips         String            // JSON string list, e.g. '["Tip 1", "Tip 2"]'
  videoUrl     String?
  imageUrl     String?
  
  workoutPlans WorkoutExercise[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

// 9. WorkoutExercise Model (Connector Table)
model WorkoutExercise {
  id            String      @id @default(cuid())
  workoutPlanId String
  exerciseId    String
  sets          Int
  reps          String      // e.g. "12" or "to failure"
  restSeconds   Int
  order         Int         // Sort order in the workout plan

  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise      Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// 10. FitnessGoal Model
model FitnessGoal {
  id        String   @id @default(cuid())
  userId    String
  type      String   // WEIGHT / STRENGTH / ENDURANCE / etc.
  title     String
  target    Float
  current   Float
  unit      String   // kg / reps / mins / etc.
  deadline  DateTime?
  status    String   // ACTIVE / COMPLETED / ABANDONED

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 11. WorkoutLog Model
model WorkoutLog {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  sets       Int?
  reps       Int?
  weight     Float?
  duration   Int?     // in seconds
  notes      String?
  date       DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 12. ProgressEntry Model
model ProgressEntry {
  id        String   @id @default(cuid())
  userId    String
  weight    Float?
  bodyFat   Float?
  chest     Float?
  waist     Float?
  hips      Float?
  biceps    Float?
  thighs    Float?
  notes     String?
  date      DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 13. DailyCalorieLog Model
model DailyCalorieLog {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime @default(now())
  caloriesConsumed Int      @default(0)
  caloriesBurned   Int      @default(0)
  waterIntakeMl    Int      @default(0)
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, date])
}

// 14. DietPlan Model
model DietPlan {
  id        String   @id @default(cuid())
  userId    String
  day       String   // MONDAY, TUESDAY, etc.
  mealType  String   // BREAKFAST, LUNCH, DINNER, SNACK
  foodName  String
  calories  Int
  protein   Float?   // in grams
  carbs     Float?   // in grams
  fat       Float?   // in grams
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 15. StepLog Model
model StepLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  steps     Int      @default(0)
  target    Int      @default(10000)
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}
